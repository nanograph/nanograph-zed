{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "nanograph_query",
      "camelcase": "NanographQuery",
      "title": "Nanograph Query",
      "scope": "source.nanograph_query",
      "file-types": [
        "gq"
      ],
      "injection-regex": "^nanograph_query$",
      "class-name": "TreeSitterNanographQuery"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Nanograph query files.",
    "authors": [
      {
        "name": "nanograph"
      }
    ],
    "links": {
      "repository": "https://github.com/nanograph/nanograph-zed"
    }
  },
  "bindings": {
    "c": true
  }
}
